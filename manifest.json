{
  "manifest_version": 3,
  "name": "RizqAnalyser",
  "version": "1.0.0",
  "description": "Scans job pages via Wikidata. Rule-based, zero AI. Scripture-backed screening. Scholar consultation mandatory.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://query.wikidata.org/*",
    "https://www.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.welcometothejungle.com/*",
    "https://*.angel.co/*",
    "https://*.monster.com/*",
    "https://*.ziprecruiter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["styles.css"]
  }],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
